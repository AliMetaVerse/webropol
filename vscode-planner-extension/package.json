{
  "name": "webropol-daily-planner",
  "displayName": "Gravity Planner",
  "description": "A VS Code planner with tabbed planning, execution, history, and AI views.",
  "version": "0.0.1",
  "publisher": "alimetaverse",
  "engines": {
    "vscode": "^1.96.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dailyPlanner",
          "title": "Gravity Planner",
          "icon": "media/planner.svg"
        }
      ]
    },
    "views": {
      "dailyPlanner": [
        {
          "id": "plannerDashboardView",
          "name": "Gravity Planner",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "planner.openDashboard",
        "title": "Gravity Planner: Open Dashboard"
      },
      {
        "command": "planner.openPlanning",
        "title": "Gravity Planner: Open Planning"
      },
      {
        "command": "planner.openExecution",
        "title": "Gravity Planner: Open Execution"
      },
      {
        "command": "planner.resetToday",
        "title": "Gravity Planner: Reset Today"
      }
    ]
  }
}