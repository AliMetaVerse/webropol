{
    "chat.tools.terminal.autoApprove": {
        "Set-Content": true,
        "/^\\$utf8NoBom = New-Object System\\.Text\\.UTF8Encoding\\(\\$false\\); \\$files = Get-ChildItem \"design-system/component-demos\" -File \\| Where-Object \\{ \\$_\\.Extension -in '\\.html','\\.ps1' \\}; foreach \\(\\$f in \\$files\\) \\{ \\$content = \\[System\\.IO\\.File\\]::ReadAllText\\(\\$f\\.FullName\\); \\[System\\.IO\\.File\\]::WriteAllText\\(\\$f\\.FullName, \\$content, \\$utf8NoBom\\) \\}; \\$settings = \"\\.vscode/settings\\.json\"; if \\(Test-Path \\$settings\\) \\{ \\$s = \\[System\\.IO\\.File\\]::ReadAllText\\(\\$settings\\); \\[System\\.IO\\.File\\]::WriteAllText\\(\\(Resolve-Path \\$settings\\), \\$s, \\$utf8NoBom\\) \\}; \"Normalized UTF-8 \\(no BOM\\) for component-demos and \\.vscode/settings\\.json\"$/": {
            "approve": true,
            "matchCommandLine": true
        }
    }
}
